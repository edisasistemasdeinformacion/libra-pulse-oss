    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {"align": "auto", "cellOptions": {"type": "auto"}, "filterable": true},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 500},
            {"color": "orange", "value": 1000},
            {"color": "red", "value": 3000}
          ]}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Endpoint"}, "properties": [{"id": "custom.width", "value": 350}]},
          {"matcher": {"id": "byName", "options": "Metodo"}, "properties": [{"id": "custom.width", "value": 80}]},
          {
            "matcher": {"id": "byName", "options": "Latencia p95"},
            "properties": [
              {"id": "unit", "value": "ms"},
              {"id": "decimals", "value": 0},
              {"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 500},
                {"color": "orange", "value": 1000},
                {"color": "red", "value": 3000}
              ]}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Peticiones/s"},
            "properties": [{"id": "unit", "value": "reqps"}, {"id": "decimals", "value": 2}]
          }
        ]
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 31},
      "id": 22,
      "options": {
        "showHeader": true,
        "sortBy": [{"displayName": "Latencia p95", "desc": true}],
        "footer": {"show": false}
      },
      "targets": [{
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "expr": "topk(10, histogram_quantile(0.95, sum by (http_target, http_method, le) (rate(http_server_duration_bucket{service_name=\"portal-galileo\"}[5m]))))",
        "refId": "A",
        "instant": true,
        "format": "table"
      }],
      "transformations": [
        {
          "id": "filterByValue",
          "options": {
            "type": "include",
            "match": "any",
            "filters": [{"fieldName": "Value", "config": {"id": "greaterOrEqual", "options": {"value": 0}}}]
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "__name__": true, "le": true, "service_name": true},
            "renameByName": {"http_target": "Endpoint", "http_method": "Metodo", "Value": "Latencia p95"}
          }
        },
        {
          "id": "sortBy",
          "options": {"sort": [{"field": "Latencia p95", "desc": true}]}
        }
      ],
      "title": "Top 10 Endpoints Mas Lentos (Django p95)",
      "description": "Verde <500ms, amarillo 500ms-1s, naranja 1-3s, rojo >3s",
      "type": "table"
    },

